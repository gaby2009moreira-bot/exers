using System;

namespace exer
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("Digite o salário: ");
            int salario = int.Parse(Console.ReadLine());

            Console.WriteLine("Digite o reajuste: ");
            double reajuste = double.Parse(Console.ReadLine());

            double aumento = salario + (salario * reajuste / 100);

            Console.WriteLine("O valor do novo salario é: " + aumento);

        }
    }
}
